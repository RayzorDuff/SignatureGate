# =========
# Postgres: SignatureGate core
# =========
SIG_DB_HOST=signaturegate-postgres
SIG_DB_PORT=5432
SIG_DB_NAME=signaturegate
SIG_DB_USER=signaturegate
SIG_DB_PASSWORD=change_me

# =========
# Postgres: MushroomProcess bridge (optional)
# - Use this as either:
#   (A) a readonly replica of MushroomProcess DB; OR
#   (B) a small cache of selected MushroomProcess fields (lot_id, strain, regulated flag, etc.)
# =========
MP_BRIDGE_DB_HOST=mushroomprocess-bridge-postgres
MP_BRIDGE_DB_PORT=5432
MP_BRIDGE_DB_NAME=mushroomprocess_bridge
MP_BRIDGE_DB_USER=mushroomprocess_bridge
MP_BRIDGE_DB_PASSWORD=change_me

# =========
# NocoDB
# =========
NC_PUBLIC_URL=https://your.nginxserver.name
# No secure attachments
NC_SECURE_ATTACHMENTS=false
# Or - one year expiry on secure attachments
#NC_SECURE_ATTACHMENTS=false
NC_ATTACHMENT_EXPIRE_SECONDS=31536000
NC_DB_HOST=nocodb-meta-postgres
NC_DB_PORT=5432
NC_DB_NAME=nocodb_meta
NC_DB_USER=nocodb
NC_DB_PASSWORD=change_me
NC_AUTH_JWT_SECRET=change_me
NC_MAX_ATTACHMENT_FIELD_SIZE=1073741824
NC_ATTACHMENT_FIELD_SIZE=104857600
NC_MAX_ATTACHMENTS_ALLOWED=20

# =========
# n8n
# =========
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me
N8N_SECURE_COOKIE=true
N8N_HOST=n8n.yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https
# This is set to 1 when nginx is enabled
N8N_PROXY_HOPS=1
WEBHOOK_URL=https://n8n.yourdomain.com/
# Tokens generaed elsewhere and used by n8n
DOCUMENSO_API_TOKEN=api_yourgeneratedtoken
NOCODB_API_TOKEN=yourgeneratedtoken

# =========
# Appsmith
# =========
APPSMITH_ENCRYPTION_PASSWORD=change_me
APPSMITH_ENCRYPTION_SALT=change_me
APPSMITH_SUPERVISOR_PASSWORD=change_me
APPSMITH_SERVER_TIMEOUT=180
APPSMITH_CODEC_SIZE=50

# =========
# Documenso (self-hosted e-sign)
# =========
# Public URL you will route via NGINX (see deploy/nginx/documenso.conf)
DOCUMENSO_PUBLIC_URL=https://documenso.yourdomain.com
DOCUMENSO_PRIVATE_JOBS_PROVIDER=local
DOCUMENSO_PRIVATE_INTERNAL_WEBAPP_URL=http://documenso:3000

# Generate random secrets (example: openssl rand -hex 32)
DOCUMENSO_NEXTAUTH_SECRET=change_me
DOCUMENSO_ENCRYPTION_KEY=change_me
DOCUMENSO_ENCRYPTION_SECONDARY_KEY=change_me

# Signing certificate passphrase (required)
DOCUMENSO_SIGNING_PASSPHRASE=change_me

# Postgres (Documenso)
DOCUMENSO_DB_HOST=documenso-postgres
DOCUMENSO_DB_PORT=5432
DOCUMENSO_DB_NAME=documenso
DOCUMENSO_DB_USER=documenso
DOCUMENSO_DB_PASSWORD=change_me

# SMTP (Documenso) - required to email signing links
DOCUMENSO_SMTP_TRANSPORT=smtp-auth
DOCUMENSO_SMTP_HOST=smtp.yourdomain.com
DOCUMENSO_SMTP_PORT=587
DOCUMENSO_SMTP_USERNAME=no-reply@yourdomain.com
DOCUMENSO_SMTP_PASSWORD=change_me
DOCUMENSO_PRIVATE_SMTP_SECURE=false
DOCUMENSO_PRIVATE_SMTP_UNSAFE_IGNORE_TLS=false
DOCUMENSO_SMTP_FROM_NAME=Your Company
DOCUMENSO_SMTP_FROM_ADDRESS=no-reply@yourdomain.com
