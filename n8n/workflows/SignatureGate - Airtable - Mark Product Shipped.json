      "parameters": {
        "jsCode": "/**\n * Expected body JSON:\n * {\n *   \"airtable_record_id\": \"rec....\",   // preferred\n *   \"mushroomprocess_product_id\": \"PROD-....\", // optional alternative lookup\n * }\n */\nconst body = $json.body || $json;\nconst airtable_record_id = body.airtable_record_id;\nconst mushroomprocess_product_id = body.mushroomprocess_product_id;\n\nif (!airtable_record_id && !mushroomprocess_product_id) {\n  throw new Error(\"Missing airtable_record_id or mushroomprocess_product_id\");\n}\n\nreturn [{ json: { airtable_record_id, mushroomprocess_product_id } }];"
      },
      "id": "2eb5783d-2183-4f0a-a773-3058bfb3d608",
      "name": "Code - Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
