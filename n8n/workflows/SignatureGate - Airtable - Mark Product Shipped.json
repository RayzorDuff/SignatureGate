        -224,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "// Input 0: Airtable - List Locations\n// Input 1: AirtableFindProduct (optional fallback)\nconst location = $('Airtable - Find Location Shipped').first()?.json;\n\n// Each item should look like { id: \"rec...\", fields: { name: \"Shipped\", ... } }\nconst shippedLocId = location?.id;\n\nif (!shippedLocId) {\n  throw new Error(\n    `Could not find 'Shipped' location. Sample names: ${locations.slice(0,10).map(r => r.fields?.name).join(\", \")}`\n  );\n}\n\n// product record id: prefer body.airtable_record_id, else from AirtableFindProduct\nlet prodRecId = $('Code - Validate Input').first().json.airtable_record_id;\n\nif (!prodRecId) {\n  const prod = $('Airtable - Find Product by product_id').first()?.json; // AirtableFindProduct\n  prodRecId = prod?.id;\n}\n\nif (!prodRecId) throw new Error(\"Could not resolve product Airtable record id.\");\n\n// product record id: prefer body.airtable_record_id, else from AirtableFindProduct\nlet prodId = $('Code - Validate Input').first().json.mushroomprocess_product_id;\n\nif (!prodId) {\n  const prod = $('Airtable - Find Product by product_id').first()?.json; // AirtableFindProduct\n  prodRecId = prod?.product_id;\n}\n\nif (!prodId) throw new Error(\"Could not resolve product Airtable product_id.\");\n\n\n\nreturn [{ json: { id: prodRecId,  product_id: prodId, storage_location: shippedLocId } }];\n"
      },
