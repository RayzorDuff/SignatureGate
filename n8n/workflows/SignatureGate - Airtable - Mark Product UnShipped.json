        "jsCode": "// Input 0: Airtable - List Locations\n// Input 1: AirtableFindProduct (optional fallback)\nconst location = $('Airtable - Find Target Location').first()?.json;\n\n// Each item should look like { id: \"rec...\", fields: { name: \"Shipped\", ... } }\nconst targetLocId = location?.id;\n\nif (!targetLocId) {\n  throw new Error(\n    `Could not find 'Shipped' location. Sample names: ${location.slice(0,10).map(r => r.fields?.name).join(\", \")}`\n  );\n}\n\nlet prodId = $('Code - Validate Input').first().json.mushroomprocess_product_id;\nconst prod = $('Airtable - Find Product by product_id').first()?.json; // AirtableFindProduct\nconst prodRecId = prod?.id;\n\nif (!prodId) throw new Error(\"Could not resolve product Airtable product_id.\");\n\nreturn [{ json: { id: prodRecId,  product_id: prodId, storage_location: targetLocId } }];\n"
