        "jsCode": "/**\n * Expected body JSON:\n * {\n *   \"mushroomprocess_product_id\": \"PROD-....\", \n * }\n */\nconst body = $json.body || $json;\nconst mushroomprocess_product_id = body.mushroomprocess_product_id;\nconst storage_location = body.storage_location;\n\nif ( !mushroomprocess_product_id) {\n  throw new Error(\"Missing mushroomprocess_product_id\");\n}\n\nif (!storage_location) {\n  throw new Error(\"Missing storage_location\");\n}\n\nreturn [{ json: { mushroomprocess_product_id, storage_location } }];"
      },
